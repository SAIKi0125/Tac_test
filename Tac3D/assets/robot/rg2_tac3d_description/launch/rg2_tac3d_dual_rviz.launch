<?xml version="1.0" ?>
<launch>
    <param name="robot_description" command="$(find xacro)/xacro '$(find rg2_tac3d_description)/urdf/rg2_tac3d_dual.urdf.xacro'" />
    <node pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" name="joint_state_publisher_gui"/>
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find rg2_tac3d_description)/rviz/rg2.rviz"/>
</launch>
