<?xml version="1.0"?>
<robot name="stick_small">
  <link name="stick">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="stick_small.obj"/>
      </geometry>
      <material name="stick_blue">
        <color rgba="0.2 0.6 0.95 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="stick_small.obj"/>
      </geometry>
    </collision>
  </link>
</robot>
